{
    "name": "jarovarga/ares-php-client",
    "description": "A framework-agnostic, PSR-compliant PHP client for the Czech ARES registry.",
    "type": "library",
    "license": "ISC",
    "homepage": "https://github.com/jarovarga/ares-php-client",
    "authors": [
        {
            "name": "Jaro Varga",
            "email": "jaro.varga@neio.sk"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "guzzlehttp/guzzle": "^7.10",
        "phpunit/phpunit": "^13.2"
    },
    "autoload": {
        "psr-4": {
            "AresApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AresApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "composer:validate": "composer validate --strict",
        "cs": "php-cs-fixer check --diff",
        "cs:fix": "php-cs-fixer fix --diff",
        "test": "phpunit",
        "check": [
            "@composer:validate",
            "@cs",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
